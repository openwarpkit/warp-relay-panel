# Секрет для авторизации запросов от панели
AGENT_SECRET=your-agent-secret-here

# Порт агента
AGENT_PORT=7580

# Имя ipset (не менять если использовали setup_relay.sh)
IPSET_NAME=warp_whitelist

# Интервал watchdog'а правил firewall (секунды)
RULES_WATCHDOG_INTERVAL=30

# Интервал сэмплера CPU/network (секунды)
METRICS_SAMPLE_INTERVAL=1

# Интервал traffic-коллектора (секунды)
TRAFFIC_INTERVAL=30

# Адрес панели для startup-resync whitelist (опционально).
# Если задано вместе с PANEL_API_KEY — на старте агент дёргает
# GET {PANEL_URL}/api/relays/{RELAY_ID}/whitelist-payload и пересобирает state.
PANEL_URL=
PANEL_API_KEY=
RELAY_ID=
