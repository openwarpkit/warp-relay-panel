# ═══════════════════════════════════════
# ENVIRONMENT VARIABLES
# ═══════════════════════════════════════

# PostgreSQL (используется и панелью, и docker-compose для контейнера db)
POSTGRES_DB=warp
POSTGRES_USER=warp
POSTGRES_PASSWORD=change-me-strong-password

# Строка подключения панели к БД.
# В docker-compose собирается автоматически из POSTGRES_* (host = db).
# Для запуска вне compose укажите явно, например:
# DATABASE_URL=postgresql://warp:change-me-strong-password@127.0.0.1:5432/warp
DATABASE_URL=postgresql://warp:change-me-strong-password@db:5432/warp

# Размер пула соединений (опционально)
# DB_POOL_MIN=1
# DB_POOL_MAX=10

# Шифрование IP (сгенерировать: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
# ВАЖНО: при миграции с Supabase оставьте ТОТ ЖЕ ключ, иначе старые IP не расшифруются.
ENCRYPTION_KEY=your-fernet-key-here

# API-ключ для бота
API_KEY=your-secret-api-key-here

# Секрет для relay-агентов (общий для всех relay)
AGENT_SECRET=your-agent-secret-here
